{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "rave",
      "camelcase": "Rave",
      "title": "Rave",
      "scope": "source.rave",
      "file-types": [
        "rave"
      ],
      "injection-regex": "^rave$",
      "class-name": "TreeSitterRave"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "A fullstack programming language to target multiple devices in the same codebase.",
    "authors": [
      {
        "name": "Mindrage",
        "email": "mindrage@live.com",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-rave",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": true
  }
}
{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/plugins/rave-vscode"
            ],
            "outFiles": [
                "${workspaceFolder}/plugins/rave-vscode/**/*.js"
            ],
            "env": {
                "RUST_BACKTRACE": "1"
            }
        }
    ]
}
